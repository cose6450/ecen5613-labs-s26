A51 MACRO ASSEMBLER  LAB2TIMER                                                            02/13/2026 12:20:44 PAGE     1


MACRO ASSEMBLER A51 V8.2.7.0
OBJECT MODULE PLACED IN .\Objects\lab2timer.obj
ASSEMBLER INVOKED BY: C:\Keil_v5\C51\BIN\A51.EXE lab2timer.a51 SET(SMALL) DEBUG PRINT(.\Listings\lab2timer.lst) OBJECT(.
                      \Objects\lab2timer.obj) EP

LOC  OBJ            LINE     SOURCE

                       1     ; Sets a timer to blink an LED every 0.76 seconds
                       2     ; Also has code to check a pin and change toggle rate
                       3     ; as well as write a sequence of values to the debug latch
                       4     ; Written by Colin Sergi
                       5     
                       6     ; P1.0 - ISR running bit
                       7     ; P1.1 - LED 
  001F                 8     TIMER_COUNT_LOWER_BYTE EQU 0x01F ;do slightly faster than 1 ms calculated so we get the tim
                             es we want
  00DC                 9     TIMER_COUNT_UPPER_BYTE EQU 0x0DC
  0001                10     TMOD_MOD_SET EQU 0x01
  004C                11     TIMER_760_MS_COUNT EQU 76
  0019                12     TIMER_250_MS_COUNT EQU 25
                      13             
  0002                14     TIMER_HIT_FLAG EQU 2
  0000                15     TIMER_EMPTY_FLAG EQU 0
  0000                16     COUNTER_ZERO EQU 0
                      17             
  0082                18     INTERRUPT_ENABLE_ENABLE_INTERRUPTS_AND_TIMER0 EQU 0x82
                      19             
                      20             
                      21     ;debug latch values
  00B4                22     DEBUG_INITIAL_VALUE EQU 0B4h ; before what??
  0666                23     DEBUG_DPTR_VALUE EQU 0666h ; el diablo
  0080                24     DEBUG_ISR_MIN_VALUE EQU 80h ;given in assignment
  007F                25     DEBUG_MAIN_LOOP_MAX_VALUE EQU 7Fh ; given in assignment
                      26     
                      27     
0000                  28     ORG 0000h
0000 806C             29             SJMP main
000B                  30     ORG 0000Bh
000B 8033             31             SJMP timer_interrupt_routine
                      32             
                      33             
                      34             
                      35             
0040                  36     ORG 0040h
0040                  37             timer_interrupt_routine:
0040 D290             38             SETB P1.0
                      39             ;debug latch
0042 EB               40             MOV A, R3
0043 3401             41             ADDC A, #1
0045 5002             42             JNC no_overflow
0047 7480             43             MOV A, #DEBUG_ISR_MIN_VALUE
0049                  44             no_overflow:
0049 FB               45             MOV R3, A
004A F0               46             MOVX @DPTR, A ; write value to debug latch
004B D902             47             DJNZ R1, exit_timer_interrupt_routine
                      48             ;if we are here, toggle led
004D B291             49             CPL P1.1
004F                  50             exit_timer_interrupt_routine:
004F 7A02             51             MOV R2, #TIMER_HIT_FLAG
0051 C28D             52             CLR TF0
0053 C290             53             CLR P1.0
0055 32               54             RETI
                      55     
0056                  56     reset_timer:
A51 MACRO ASSEMBLER  LAB2TIMER                                                            02/13/2026 12:20:44 PAGE     2

                      57             ;setup the 8051 to count for 0.01 = 100Hz
                      58             ;timer will increment once every 921.6 kHz
                      59             ;so we need to go through  921.6 kHz/ 100Hz = 9216 cycles of the timer to get the p
                             eriod
                      60             ;when counting up, do (2^16 - 9216)
                      61             ;count that 76 times
                      62             
0056 C28C             63             CLR TR0
                      64             
                      65             
                      66             
                      67             ;set the TMOD register
0058 758901           68             MOV TMOD, #TMOD_MOD_SET ;set to 16 bit timer mod and used as a timer not a counter
                      69             
                      70             ;set the time count
005B 758CDC           71             MOV TH0, #TIMER_COUNT_UPPER_BYTE
005E 758A1F           72             MOV TL0, #TIMER_COUNT_LOWER_BYTE
                      73             
                      74             
                      75             
                      76             ;start the timer
0061 D28C             77             SETB TR0
0063 22               78             RET
0064                  79     get_timer_count:
0064 209304           80             JB P1.3, do_250_ms_count ;detect whether or not we are doing the fast blink or the 
                             slow blink
0067 794C             81             MOV R1, #TIMER_760_MS_COUNT ;if low, do 0.66Hz
0069 8002             82             SJMP return_get_timer_count
006B                  83             do_250_ms_count:
006B 7919             84             MOV R1, #TIMER_250_MS_COUNT ;if high, do 2Hz
006D                  85             return_get_timer_count:
006D 22               86             RET
                      87     
006E                  88     main:
                      89             ; turn off the two output pins
006E C290             90             CLR P1.0 
0070 00               91             NOP
0071 C291             92             CLR P1.1 
0073 00               93             NOP
                      94             
                      95             ;set debug latch to known initial value
0074 900666           96             MOV DPTR, #DEBUG_DPTR_VALUE
0077 74B4             97             MOV A, #DEBUG_INITIAL_VALUE
0079 F0               98             MOVX @DPTR, A
                      99             
                     100             ;set debug latch register to initial values
007A 7B80            101             MOV R3, #DEBUG_ISR_MIN_VALUE
007C 7C00            102             MOV R4, #0
                     103             
                     104             
                     105             ;count to the appropriate value
007E 1164            106             ACALL get_timer_count
                     107             ;set the reset flag to off
0080 7A00            108             MOV R2, #TIMER_EMPTY_FLAG
                     109             ;configure the first timer
0082 1156            110             ACALL reset_timer
                     111             
                     112             ;enable interrupts
0084 75A882          113             MOV IE, #INTERRUPT_ENABLE_ENABLE_INTERRUPTS_AND_TIMER0 ; enable interrupts and time
                             r 0 interrupt
                     114             
                     115             
                     116             ;loop forever
0087                 117     inf_loop:
0087 BA0009          118             CJNE R2, #TIMER_EMPTY_FLAG, do_timer_reset
008A 0B              119             INC R3
A51 MACRO ASSEMBLER  LAB2TIMER                                                            02/13/2026 12:20:44 PAGE     3

008B BB8002          120             CJNE R3, #DEBUG_ISR_MIN_VALUE, no_overflow_main
008E 7B00            121             MOV R3, #0
0090                 122             no_overflow_main:
0090 F0              123             MOVX @DPTR, A
0091 0187            124             AJMP inf_loop
0093                 125     do_timer_reset:
0093 B90002          126             CJNE R1, #COUNTER_ZERO, reset_isr ; determine whether or not we need to also reset 
                             the counter
0096 1164            127             ACALL get_timer_count
0098                 128             reset_isr:
0098 7A00            129             MOV R2, #TIMER_EMPTY_FLAG
009A 1156            130             ACALL reset_timer
009C 80E9            131             SJMP inf_loop
                     132             END
                                     
